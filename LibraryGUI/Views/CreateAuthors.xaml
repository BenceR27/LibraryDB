<Page x:Class="LibraryGUI.Views.CreateAuthors"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LibraryGUI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateAuthors">

    <Grid Margin="0,0,-21,10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.RowSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="200">

            <Label Content="Adja meg a szerző nevét"
                   Foreground="White"
               FontWeight="Bold"
               Margin="0,0,0,5"/>

            <Border BorderBrush="White"
                BorderThickness="0,0,0,2"
                Margin="0,0,0,15">

                <TextBox x:Name="authorText"
                     BorderThickness="0"
                         Foreground="White"
                     Background="Gray"
                     Height="30"
                     FontSize="14"/>
            </Border>

            <Button Content="Hozzáadás"
                Height="35"
                FontWeight="Bold"
                Background="DarkSeaGreen"
                Foreground="White"
                Click="Button_Click"/>

        </StackPanel>
    </Grid>
</Page>
