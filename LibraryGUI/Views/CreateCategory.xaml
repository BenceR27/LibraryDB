<Page x:Class="LibraryGUI.Views.CreateCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LibraryGUI.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateCategory">
    <Page.Background>
        <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
            <GradientStop Color="#FF373438" Offset="0.126"/>
            <GradientStop Color="#FF041D4E" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Margin="0,0,-21,10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="200">

            <Label Content="Kategória"
                   Foreground="White"
           FontWeight="Bold"
           Margin="0,0,0,5"/>

            <Border BorderBrush="White"
            BorderThickness="0,0,0,2"
            Margin="0,0,0,15">

                <TextBox x:Name="categoryText"
                 BorderThickness="0"
                 Background="Gray"
                 Foreground="White"
                 Height="30"
                 FontSize="14"/>
            </Border>


            <Button Content="Hozzáadás"
            Height="40"
            FontWeight="Bold"
            Background="DarkSeaGreen"
            Foreground="White"
            Click="Button_Click"/>

        </StackPanel>
    </Grid>
</Page>
