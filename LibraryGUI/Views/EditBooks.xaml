<Window x:Class="LibraryGUI.Views.EditBooks"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Könyv szerkesztése"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
            <GradientStop Color="#FF373438" Offset="0.126"/>
            <GradientStop Color="#FF041D4E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Könyv adatai"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Cím" Foreground="White" FontWeight="Bold"/>
            <TextBox x:Name="tbTitle"
                     IsReadOnly="True"
                     Background="#334"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Kiadás dátuma" Foreground="White" FontWeight="Bold"/>
            <DatePicker x:Name="dpPublishDate"
                Height="32"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Szerző" Foreground="White" FontWeight="Bold"/>
            <ComboBox x:Name="cbAuthors"
                      Height="32"
                      DisplayMemberPath="AuthorName"
                      SelectedValuePath="AuthorId"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Kategória" Foreground="White" FontWeight="Bold"/>
            <ComboBox x:Name="cbCategories"
                      Height="32"
                      DisplayMemberPath="CategoryName"
                      SelectedValuePath="CategoryId"/>
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">

            <Button Content="Mentés"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="BtnSave_Click"
                    Background="DarkSeaGreen"
                    Foreground="White"
                    FontWeight="Bold"/>

            <Button Content="Törlés"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="BtnDelete_Click"
                    Background="#CC4444"
                    Foreground="White"
                    FontWeight="Bold"/>

            <Button Content="Mégse"
                    Width="90"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>